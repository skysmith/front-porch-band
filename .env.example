# Front Porch Band local config
# Copy to .env and fill in anything you want to use.

# Optional chart directory override.
# Default behavior prefers ./private-charts if it exists.
# FRONT_PORCH_CHARTS_DIR=./private-charts

# Optional import overrides.
# FRONT_PORCH_IMPORT_INBOX=./private-build/import
# FRONT_PORCH_IMPORT_ARCHIVE=./private-build/import-archive

# Suggestion inbox via GitHub Issues.
# Use a fine-grained token with Issues read/write on your target repo.
# FRONT_PORCH_GITHUB_REPO=owner/repo
# FRONT_PORCH_GITHUB_TOKEN=github_pat_xxx
# FRONT_PORCH_GITHUB_LABELS=song-suggestion
